<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">
    <changeSet id="2024-10-05 add dem_info table" author="akudryashov">
        <createTable tableName="terrain" remarks="Террейны">
            <column name="id" type="uuid" remarks="Идентификатор записи">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="resolution" type="varchar(10)" remarks="Настройки разрешения">
                <constraints nullable="false"/>
            </column>
            <column name="row_key" type="varchar(50)" remarks="Поисковый индекс (lat + lon)">
                <constraints nullable="false"/>
            </column>
            <column name="row_hash" type="int" remarks="Хэш поискового индекса">
                <constraints nullable="false"/>
            </column>
            <column name="storage_path" type="varchar(100)" remarks="Путь в хранилище">
                <constraints nullable="false"/>
            </column>
            <column name="created_date" type="timestamp" remarks="Дата создания записи" defaultValue="now()">
                <constraints nullable="false"/>
            </column>
            <column name="last_modified_date" type="timestamp" remarks="Дата изменения записи" defaultValue="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="terrain" indexName="idx_row_hash">
            <column name="row_hash"/>
        </createIndex>
        <createIndex tableName="terrain" indexName="idx_row_key" unique="true">
            <column name="row_key"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
